    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "df = pd.read_csv(\"splits_updated.csv\")\n",
    "\n",
    "# divide in 3 parti il più possibile uguali\n",
    "splits = np.array_split(df, 3)\n",
    "\n",
    "for i, split in enumerate(splits):\n",
    "    split.to_csv(f\"splits/s_updated_{i+1}.csv\", index=False)"
   ]
